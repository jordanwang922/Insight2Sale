DATABASE_URL="postgresql://jordanwang@localhost:5432/insight2sale?schema=public"
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://192.168.71.53:3001"
ARK_API_KEY="replace-with-your-ark-api-key"
ARK_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
ARK_MODEL="doubao-seed-1-6-251015"
ARK_TIMEOUT_MS="8000"

# 通话录音 → 文字：优先使用「豆包语音」大模型录音文件极速版（与方舟对话密钥不同，需在火山控制台单独开通）
# VOLC_SPEECH_APP_KEY="控制台应用 AppKey / AppId"
# VOLC_SPEECH_ACCESS_KEY="控制台 Access Key"
# VOLC_SPEECH_RESOURCE_ID="volc.bigasr.auc_turbo"
#
# 通话纪要 / 要点：使用上方 ARK_* 方舟大模型（与解读台一致）
#
# 备选：仅当未配置豆包语音时，可用 OpenAI Whisper 转写（不推荐生产长期依赖）
# OPENAI_API_KEY="sk-..."

# PDF 知识库上传：对扫描页 / 图片内文字做 OCR（Tesseract，中英）
# PDF_OCR_DISABLE=1
# PDF_OCR_MODE=hybrid
# hybrid=省算力（短文档或文本稀疏页才整页 OCR）；full=每页都 OCR（图文混排更完整，更慢）
# PDF_OCR_MAX_PAGES=40
# PDF_OCR_RENDER_SCALE=1.75
# PDF_OCR_MIN_PAGE_TEXT_CHARS=90
# PDF_OCR_SHORT_DOC_THRESHOLD=220

# 解读台 SOP：强制使用仓库内 interpretation-desk-template.txt（忽略知识库《解读台模版》切片）。本地改模版后刷新仍无变化时设为 true。
# INTERPRETATION_DESK_USE_REPO_TEMPLATE=true
