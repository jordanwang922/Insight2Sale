{
  "name": "insight2sale",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev --webpack -p 3001 -H 0.0.0.0",
    "dev:turbo": "next dev -p 3001 -H 0.0.0.0",
    "build": "prisma generate && next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:start": "docker compose up -d postgres",
    "db:stop": "docker compose stop postgres",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "node --import tsx prisma/seed.ts",
    "provision-admin-sql": "node --import tsx scripts/generate-provision-admin-sql.ts",
    "db:reembed-knowledge": "node --import tsx --env-file=.env scripts/reembed-knowledge-embeddings.ts",
    "assessment:gen-from-docx": "python3 scripts/build_assessment_from_docx.py",
    "assessment:verify-word": "python3 scripts/verify_word_vs_repo.py"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@napi-rs/canvas": "^0.1.80",
    "@prisma/client": "^6.16.3",
    "bcryptjs": "^3.0.2",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.542.0",
    "mammoth": "^1.12.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.29",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.4.296",
    "prisma": "^6.16.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.62.0",
    "tailwind-merge": "^3.3.1",
    "tesseract.js": "6.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.1.8",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^27.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}
